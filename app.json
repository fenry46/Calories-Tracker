{
  "expo": {
    "name": "NutriPen",
    "slug": "calorie-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fenry46.nutripen",
      "infoPlist": {
        "NSCameraUsageDescription": "We use the camera to scan your food and estimate its calories.",
        "NSPhotoLibraryUsageDescription": "We let you pick food photos from your library to estimate calories."
      }
    },
    "android": {
      "package": "com.fenry46.nutripen",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "We use the camera to scan your food and estimate its calories."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "We let you pick food photos from your library to estimate calories."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "cf6a829a-b5c9-423e-973a-ab973529ab62"
      }
    }
  }
}
